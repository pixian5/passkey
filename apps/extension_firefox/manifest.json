{
  "manifest_version": 3,
  "name": "Pass - Firefox Extension",
  "description": "Password manager extension for Firefox with device name, domain alias group, and local account storage.",
  "version": "0.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "pass@pixian5.github.io",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "clipboardRead",
    "clipboardWrite",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Pass",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background.js",
    "scripts": [
      "dist/background.js"
    ]
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "webauthn_injected.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
