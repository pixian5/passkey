{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codex-tauri",
  "version": "0.2.0",
  "identifier": "com.pixian5.pass.codextauri",
  "build": {
    "beforeDevCommand": "npm run prepare:dist",
    "beforeBuildCommand": "npm run prepare:dist",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "codex-tauri",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "appimage", "deb", "dmg", "msi", "nsis"],
    "icon": [],
    "category": "Productivity",
    "shortDescription": "pass 桌面端 Tauri 版本",
    "longDescription": "用于 Windows、Ubuntu 和 macOS 的 pass 桌面端。",
    "createUpdaterArtifacts": false
  }
}
